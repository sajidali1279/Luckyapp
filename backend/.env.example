# ─── Database (Neon / PostgreSQL) ───────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST-DIRECT/DB?sslmode=require"

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="30d"

# ─── Firebase Admin SDK (push notifications only) ───────────────────────────
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"

# ─── Cloudinary (receipt image storage) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins (admin portal URL)
# React Native mobile app has no origin and is always allowed
ALLOWED_ORIGINS="https://your-admin-portal.com,http://localhost:5173"

# ─── App ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Points rates ────────────────────────────────────────────────────────────
DEFAULT_CASHBACK_RATE=0.05
DEV_CUT_RATE=0.04

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  DEV_ADMIN    // Developer (you) — full access + billing
  SUPER_ADMIN  // LuckyStop HQ — all stores, offers, banners
  STORE_MANAGER // Per-store management
  EMPLOYEE     // Scan QR, upload receipt, grant points
  CUSTOMER     // Mobile app user
}

enum BillingType {
  MONTHLY_SUBSCRIPTION
  PER_TRANSACTION
  HYBRID
}

enum TransactionStatus {
  PENDING    // Waiting for receipt upload
  APPROVED   // Points granted
  REJECTED   // Rejected by admin/auto
}

enum OfferType {
  ALL_STORES   // Applies to all 14 stores
  SPECIFIC_STORE
}

enum ProductCategory {
  GROCERIES
  FROZEN_FOODS
  FRESH_FOODS
  GAS
  DIESEL
  TOBACCO_VAPES
  HOT_FOODS
  OTHER
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(uuid())
  phone           String   @unique
  name            String?
  role            Role     @default(CUSTOMER)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Auth — phone + PIN (no OTP, no Firebase Auth)
  pinHash         String?
  isProfileComplete Boolean @default(false)

  // Customer-specific
  qrCode          String?  @unique
  pointsBalance   Float    @default(0)

  // Relations
  storeRoles           UserStoreRole[]
  pointsEarned         PointsTransaction[]  @relation("PointsEarner")
  pointsGranted        PointsTransaction[]  @relation("PointsGranter")
  redemptions          Redemption[]
  creditRedemptions    CreditRedemption[]   @relation("CustomerRedemptions")
  processedRedemptions CreditRedemption[]   @relation("ProcessorRedemptions")
  pushTokens           PushToken[]

  @@map("users")
}

model Store {
  id          String   @id @default(uuid())
  name        String
  address     String
  city        String
  state       String
  zipCode     String
  phone       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Billing (managed by DevAdmin only)
  billingType       BillingType @default(MONTHLY_SUBSCRIPTION)
  subscriptionPrice Float       @default(99.00)
  transactionFeeRate Float      @default(0.02)

  // Relations
  userRoles         UserStoreRole[]
  transactions      PointsTransaction[]
  creditRedemptions CreditRedemption[]
  offers            Offer[]
  banners           Banner[]
  billing           BillingRecord[]

  @@map("stores")
}

// Links employees/managers to their specific stores
model UserStoreRole {
  id        String   @id @default(uuid())
  userId    String
  storeId   String
  role      Role
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@map("user_store_roles")
}

// ─── Points System ────────────────────────────────────────────────────────────

model PointsTransaction {
  id              String            @id @default(uuid())
  customerId      String
  grantedById     String
  storeId         String
  purchaseAmount  Float
  pointsAwarded   Float             // cashback credited to customer
  devCut          Float             // legacy field — now always 0 (dev earns on redemption)
  storeCost       Float             // = pointsAwarded (store bears cashback cost)
  cashbackRate    Float             @default(0.05) // rate used at time of grant
  category        ProductCategory   @default(OTHER)
  status          TransactionStatus @default(PENDING)
  receiptImageUrl String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  customer    User  @relation("PointsEarner", fields: [customerId], references: [id])
  grantedBy   User  @relation("PointsGranter", fields: [grantedById], references: [id])
  store       Store @relation(fields: [storeId], references: [id])

  @@index([customerId])
  @@index([storeId])
  @@index([status])
  @@index([createdAt])
  @@index([storeId, status, createdAt])
  @@map("points_transactions")
}

// ─── Category Cashback Rates (DevAdmin configurable) ─────────────────────────

model CategoryRate {
  category     ProductCategory @id
  cashbackRate Float           @default(0.05)
  updatedAt    DateTime        @updatedAt

  @@map("category_rates")
}

// Tracks when a customer uses their credit balance in-store
model CreditRedemption {
  id          String   @id @default(uuid())
  customerId  String
  storeId     String
  amount      Float                       // Credits redeemed
  devCut      Float    @default(0)        // Platform fee (% of redeemed amount)
  processedBy String
  createdAt   DateTime @default(now())

  customer  User  @relation("CustomerRedemptions", fields: [customerId], references: [id])
  store     Store @relation(fields: [storeId], references: [id])
  processor User  @relation("ProcessorRedemptions", fields: [processedBy], references: [id])

  @@index([customerId])
  @@index([createdAt])
  @@map("credit_redemptions")
}

// ─── Offers & Promotions ──────────────────────────────────────────────────────

model Offer {
  id          String      @id @default(uuid())
  title       String
  description String
  imageUrl    String?
  type        OfferType   @default(ALL_STORES)
  storeId     String?
  category    ProductCategory?
  bonusRate   Float?      // cashback promotion rate (auto-applied at grant time)
  dealText    String?     // price deal label e.g. "2 for $5" (display only)
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  store Store? @relation(fields: [storeId], references: [id])

  @@index([isActive, startDate, endDate])
  @@index([storeId])
  @@map("offers")
}

model Banner {
  id        String    @id @default(uuid())
  title     String
  imageUrl  String
  linkUrl   String?
  storeId   String?
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  store Store? @relation(fields: [storeId], references: [id])

  @@index([isActive, storeId])
  @@map("banners")
}

// ─── Rewards (future catalog) ─────────────────────────────────────────────────

model Reward {
  id            String   @id @default(uuid())
  name          String
  description   String
  imageUrl      String?
  pointsCost    Float
  isActive      Boolean  @default(true)
  stockLimit    Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  redemptions Redemption[]

  @@map("rewards")
}

model Redemption {
  id          String   @id @default(uuid())
  customerId  String
  rewardId    String
  pointsSpent Float
  redeemedAt  DateTime @default(now())
  verifiedAt  DateTime?
  verifiedBy  String?

  customer User   @relation(fields: [customerId], references: [id])
  reward   Reward @relation(fields: [rewardId], references: [id])

  @@index([customerId])
  @@index([redeemedAt])
  @@map("redemptions")
}

// ─── Billing (DevAdmin only) ──────────────────────────────────────────────────

model BillingRecord {
  id          String   @id @default(uuid())
  storeId     String
  billingType BillingType
  amount      Float
  period      String
  isPaid      Boolean  @default(false)
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id])

  @@map("billing_records")
}

// ─── Push Notifications ───────────────────────────────────────────────────────

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_tokens")
}

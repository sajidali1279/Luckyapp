generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum StoreRequestType {
  LOW_STOCK
  STORE_SUPPLIES
  CUSTOMER_REQUESTED_PRODUCT
  WORK_ORDER
}

enum StoreRequestPriority {
  LOW
  MEDIUM
  HIGH
}

enum StoreRequestStatus {
  PENDING
  ACKNOWLEDGED
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum ShiftType {
  OPENING
  MIDDLE
  CLOSING
}

enum ShiftRequestType {
  TIME_OFF
  FILL_IN
}

enum RequestStatus {
  PENDING
  APPROVED
  DENIED
}

enum Role {
  DEV_ADMIN    // Developer (you) — full access + billing
  SUPER_ADMIN  // LuckyStop HQ — all stores, offers, banners
  STORE_MANAGER // Per-store management
  EMPLOYEE     // Scan QR, upload receipt, grant points
  CUSTOMER     // Mobile app user
}

enum BillingType {
  MONTHLY_SUBSCRIPTION
  PER_TRANSACTION
  HYBRID
}

enum TransactionStatus {
  PENDING    // Waiting for receipt upload
  APPROVED   // Points granted
  REJECTED   // Rejected by admin/auto
}

enum OfferType {
  ALL_STORES   // Applies to all 14 stores
  SPECIFIC_STORE
}

enum ProductCategory {
  GROCERIES
  FROZEN_FOODS
  FRESH_FOODS
  GAS
  DIESEL
  TOBACCO_VAPES
  HOT_FOODS
  OTHER
}

enum Tier {
  BRONZE
  SILVER
  GOLD
  DIAMOND
  PLATINUM
}

enum PromoStatus {
  PENDING    // Customer submitted, awaiting DevAdmin review
  APPROVED   // DevAdmin published — visible to all customers
  REJECTED   // DevAdmin rejected
}

// ─── Core Models ──────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(uuid())
  phone           String   @unique
  name            String?
  role            Role     @default(CUSTOMER)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Auth — phone + PIN
  pinHash         String?
  pinHistory      String[] // last 3 PIN hashes (prevent reuse)
  isProfileComplete Boolean @default(false)

  // Tier system
  tier            Tier     @default(BRONZE)
  periodPoints    Float    @default(0)   // points earned this period (in dollars, × 100 = pts for display)
  tierPeriod      String   @default("2026-H1")  // "YYYY-H1" or "YYYY-H2"

  // Account recovery
  email           String?  @unique
  emailVerified   Boolean  @default(false)

  // Login rate limiting
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // Customer-specific
  qrCode          String?  @unique
  pointsBalance   Float    @default(0)

  // Relations
  storeRoles           UserStoreRole[]
  pointsEarned         PointsTransaction[]  @relation("PointsEarner")
  pointsGranted        PointsTransaction[]  @relation("PointsGranter")
  redemptions          Redemption[]
  creditRedemptions    CreditRedemption[]   @relation("CustomerRedemptions")
  processedRedemptions CreditRedemption[]   @relation("ProcessorRedemptions")
  pushTokens           PushToken[]
  notifications        UserNotification[]
  tierBenefitClaims         TierBenefitClaim[]
  catalogRedemptions        CatalogRedemption[]  @relation("CatalogCustomer")
  processedCatalogRedemptions CatalogRedemption[] @relation("CatalogProcessor")
  shiftTemplates       ShiftTemplate[]      @relation("EmployeeShifts")
  shiftRequests        ShiftRequest[]       @relation("EmployeeRequests")
  chatMessages         ChatMessage[]
  submittedStoreRequests StoreRequest[]
  businessPromotions     BusinessPromotion[]

  @@map("users")
}

model Store {
  id          String   @id @default(uuid())
  name        String
  address     String
  city        String
  state       String
  zipCode     String
  phone       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Billing (managed by DevAdmin only)
  billingType       BillingType @default(MONTHLY_SUBSCRIPTION)
  subscriptionPrice Float       @default(99.00)
  transactionFeeRate Float      @default(0.02)

  // Scheduling
  shiftsPerDay      Int         @default(3)  // 2 or 3 shifts per day

  // Location (for customer proximity detection)
  latitude          Float?
  longitude         Float?

  // Gas prices (updated daily by admins)
  gasPricePerGallon    Float?
  dieselPricePerGallon Float?
  gasPriceUpdatedAt    DateTime?

  // Printer agent authentication
  apiKey            String?     @unique

  // Relations
  userRoles         UserStoreRole[]
  transactions      PointsTransaction[]
  creditRedemptions CreditRedemption[]
  offers            Offer[]
  banners           Banner[]
  billing           BillingRecord[]
  receiptTokens     ReceiptToken[]
  shiftTemplates    ShiftTemplate[]
  shiftRequests     ShiftRequest[]
  chatMessages      ChatMessage[]
  storeRequests     StoreRequest[]
  catalogRedemptions CatalogRedemption[]

  @@map("stores")
}

// Links employees/managers to their specific stores
model UserStoreRole {
  id        String   @id @default(uuid())
  userId    String
  storeId   String
  role      Role
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@map("user_store_roles")
}

// ─── Points System ────────────────────────────────────────────────────────────

model PointsTransaction {
  id              String            @id @default(uuid())
  customerId      String
  grantedById     String
  storeId         String
  purchaseAmount  Float
  pointsAwarded   Float             // cashback credited to customer
  devCut          Float             // dev's cut of cashback issued (taken at grant time)
  storeCost       Float             // full cashback issued — store bears this cost
  cashbackRate    Float             @default(0.05) // rate used at time of grant
  category        ProductCategory   @default(OTHER)
  status          TransactionStatus @default(PENDING)
  receiptImageUrl String?
  notes           String?
  isGas             Boolean @default(false)
  gasGallons        Float?
  gasPricePerGallon Float?
  gasBonusPoints    Float   @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  customer    User  @relation("PointsEarner", fields: [customerId], references: [id])
  grantedBy   User  @relation("PointsGranter", fields: [grantedById], references: [id])
  store       Store @relation(fields: [storeId], references: [id])

  @@index([customerId])
  @@index([storeId])
  @@index([status])
  @@index([createdAt])
  @@index([storeId, status, createdAt])
  @@map("points_transactions")
}

// ─── Category Cashback Rates (DevAdmin configurable) ─────────────────────────

model CategoryRate {
  category     ProductCategory @id
  cashbackRate Float           @default(0.05)
  updatedAt    DateTime        @updatedAt

  @@map("category_rates")
}

// Tracks when a customer uses their credit balance in-store
model CreditRedemption {
  id          String   @id @default(uuid())
  customerId  String
  storeId     String
  amount      Float                       // Credits redeemed
  devCut      Float    @default(0)        // Platform fee (% of redeemed amount)
  processedBy String
  createdAt   DateTime @default(now())

  customer  User  @relation("CustomerRedemptions", fields: [customerId], references: [id])
  store     Store @relation(fields: [storeId], references: [id])
  processor User  @relation("ProcessorRedemptions", fields: [processedBy], references: [id])

  @@index([customerId])
  @@index([createdAt])
  @@map("credit_redemptions")
}

// ─── Offers & Promotions ──────────────────────────────────────────────────────

model Offer {
  id          String      @id @default(uuid())
  title       String
  description String
  imageUrl    String?
  type        OfferType   @default(ALL_STORES)
  storeId     String?
  category    ProductCategory?
  bonusRate   Float?      // cashback promotion rate (auto-applied at grant time)
  dealText    String?     // price deal label e.g. "2 for $5" (display only)
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  store Store? @relation(fields: [storeId], references: [id])

  @@index([isActive, startDate, endDate])
  @@index([storeId])
  @@map("offers")
}

model Banner {
  id        String    @id @default(uuid())
  title     String
  imageUrl  String
  linkUrl   String?
  storeId   String?
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  store Store? @relation(fields: [storeId], references: [id])

  @@index([isActive, storeId])
  @@map("banners")
}

// ─── Rewards (future catalog) ─────────────────────────────────────────────────

model Reward {
  id            String   @id @default(uuid())
  name          String
  description   String
  imageUrl      String?
  pointsCost    Float
  isActive      Boolean  @default(true)
  stockLimit    Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  redemptions Redemption[]

  @@map("rewards")
}

model Redemption {
  id          String   @id @default(uuid())
  customerId  String
  rewardId    String
  pointsSpent Float
  redeemedAt  DateTime @default(now())
  verifiedAt  DateTime?
  verifiedBy  String?

  customer User   @relation(fields: [customerId], references: [id])
  reward   Reward @relation(fields: [rewardId], references: [id])

  @@index([customerId])
  @@index([redeemedAt])
  @@map("redemptions")
}

// ─── Billing (DevAdmin only) ──────────────────────────────────────────────────

model BillingRecord {
  id          String   @id @default(uuid())
  storeId     String
  billingType BillingType
  amount      Float
  period      String
  notes       String?  // JSON: full compound breakdown (rates, categories, fee split)
  isPaid      Boolean  @default(false)
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id])

  @@map("billing_records")
}

// ─── Receipt QR Tokens (printer agent → customer self-grant) ─────────────────

model ReceiptToken {
  id        String    @id @default(uuid())
  storeId   String
  txRef     String    // POS transaction reference — prevents duplicate QR generation
  total     Float
  items     String    // JSON: [{category: ProductCategory, amount: number}]
  usedBy    String?   // customer userId who claimed it
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  store Store @relation(fields: [storeId], references: [id])

  @@unique([storeId, txRef])
  @@index([expiresAt])
  @@map("receipt_tokens")
}

// ─── Platform Config (DevAdmin key-value store) ───────────────────────────────

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_config")
}

// ─── Audit Log (DevAdmin fraud monitoring) ───────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  actorName  String?
  actorRole  String
  action     String   // CREATE_OFFER, DELETE_OFFER, CREATE_BANNER, DELETE_BANNER, GRANT_POINTS, REJECT_TRANSACTION, REDEEM_CREDITS, CREATE_STAFF, TOGGLE_USER, RESET_PIN, SELF_GRANT
  entity     String   // offer, banner, transaction, staff, user
  entityId   String?
  details    String?  // JSON: context fields (amounts, names, etc.)
  storeId    String?
  storeName  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([actorId])
  @@index([storeId])
  @@index([action])
  @@map("audit_logs")
}

// ─── Scheduling ───────────────────────────────────────────────────────────────

model ShiftTemplate {
  id         String    @id @default(uuid())
  employeeId String
  storeId    String
  dayOfWeek  DayOfWeek
  shiftType  ShiftType
  startTime  String    // "06:00", "10:00", or "14:00"
  endTime    String    // "14:00", "18:00", or "22:00"
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employee User  @relation("EmployeeShifts", fields: [employeeId], references: [id], onDelete: Cascade)
  store    Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, storeId, dayOfWeek])
  @@index([storeId])
  @@index([employeeId])
  @@map("shift_templates")
}

model ShiftRequest {
  id          String           @id @default(uuid())
  employeeId  String
  storeId     String
  requestType ShiftRequestType
  date        DateTime
  shiftType   ShiftType
  status      RequestStatus    @default(PENDING)
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  employee User  @relation("EmployeeRequests", fields: [employeeId], references: [id], onDelete: Cascade)
  store    Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, date])
  @@index([employeeId])
  @@map("shift_requests")
}

// ─── Store Chat ───────────────────────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(uuid())
  storeId   String
  userId    String
  userName  String   // denormalized for display
  userRole  String   // denormalized for role badge
  text      String
  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt])
  @@map("chat_messages")
}

// ─── Store Requests ───────────────────────────────────────────────────────────

model StoreRequest {
  id               String               @id @default(uuid())
  storeId          String
  submittedById    String
  submitterName    String
  submitterRole    String
  type             StoreRequestType
  priority         StoreRequestPriority
  notes            String?
  status           StoreRequestStatus   @default(PENDING)
  acknowledgedById String?
  acknowledgerName String?
  acknowledgerNote String?
  acknowledgedAt   DateTime?
  createdAt        DateTime             @default(now())

  store       Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  submittedBy User  @relation(fields: [submittedById], references: [id], onDelete: Cascade)

  @@index([storeId, status])
  @@index([submittedById])
  @@map("store_requests")
}

// ─── OTP Codes (PIN recovery) ─────────────────────────────────────────────────

model OtpCode {
  id        String   @id @default(uuid())
  phone     String
  email     String?
  code      String
  purpose   String   // "FORGOT_PIN"
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone, purpose])
  @@map("otp_codes")
}

// ─── In-App Notifications ─────────────────────────────────────────────────────

model UserNotification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String   // "OFFER" | "POINTS" | "REDEMPTION" | "SCHEDULE" | "SHIFT_REQUEST" | "STORE_REQUEST"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("user_notifications")
}

// ─── Push Notifications ───────────────────────────────────────────────────────

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_tokens")
}

// ─── Redemption Catalog ────────────────────────────────────────────────────────

model RedemptionCatalogItem {
  id          String   @id @default(uuid())
  chain       String   @default("Lucky Stop") // company/brand this item belongs to
  category    String   @default("IN_STORE")  // IN_STORE | GAS | HOT_FOODS
  title       String
  description String   @default("")
  emoji       String   @default("🎁")
  pointsCost  Int      // cost in points (e.g. 400 = 400 pts = $4 redeemable value)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  redemptions CatalogRedemption[]

  @@map("redemption_catalog_items")
}

model CatalogRedemption {
  id              String    @id @default(uuid())
  customerId      String
  catalogItemId   String
  pointsSpent     Int       // points cost at time of redemption
  status          String    @default("COMPLETED") // PENDING | COMPLETED | EXPIRED | CANCELLED
  redemptionCode  String?   @unique              // 6-char code for employee to confirm
  expiresAt       DateTime?                       // 30 min from initiation for PENDING
  storeId         String?
  processedById   String?
  createdAt       DateTime  @default(now())

  customer    User                  @relation("CatalogCustomer", fields: [customerId], references: [id])
  catalogItem RedemptionCatalogItem @relation(fields: [catalogItemId], references: [id])
  store       Store?                @relation(fields: [storeId], references: [id])
  processedBy User?                 @relation("CatalogProcessor", fields: [processedById], references: [id])

  @@index([customerId])
  @@index([status])
  @@map("catalog_redemptions")
}

// ─── Business Promotions ──────────────────────────────────────────────────────

model BusinessPromotion {
  id               String      @id @default(uuid())
  // Requester info (submitted by customer)
  requesterId      String
  requesterName    String
  requesterPhone   String
  businessName     String
  businessDescription String
  website          String?
  // DevAdmin publish content
  status           PromoStatus @default(PENDING)
  adTitle          String?
  adBody           String?
  adImageUrl       String?
  adExpiresAt      DateTime?
  devAdminNote     String?
  publishedAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  requester User @relation(fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([requesterId])
  @@map("business_promotions")
}

// ─── Tier Benefit Claims ──────────────────────────────────────────────────────

model TierBenefitClaim {
  id          String   @id @default(uuid())
  userId      String
  period      String   // "2026-H1"
  claimedAt   DateTime @default(now())
  benefitType String   // "SILVER_FOUNTAIN" | "DAILY_DRINK"

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, period])
  @@map("tier_benefit_claims")
}

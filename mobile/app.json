{
  "expo": {
    "name": "Lucky Stop",
    "slug": "luckystop",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1D3557",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.luckystop.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E63946"
      },
      "package": "com.luckystop.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Lucky Stop needs access to your photo library so you can upload a business logo or image for your promotion.",
          "cameraPermission": "Lucky Stop needs access to your camera to take a photo for your promotion."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Lucky Stop uses Face ID to let you sign in quickly without typing your PIN."
        }
      ]
    ],
    "scheme": "luckystop",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c13d7114-4241-4e51-ad30-d69096d570ee"
      }
    },
    "owner": "sajid1017"
  }
}

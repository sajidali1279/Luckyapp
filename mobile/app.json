{
  "expo": {
    "name": "Lucky Stop",
    "slug": "luckystop",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.luckystop.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E63946"
      },
      "package": "com.luckystop.app"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-secure-store"
    ],
    "scheme": "luckystop"
  }
}
